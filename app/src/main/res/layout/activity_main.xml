<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <!-- WebView dibungkus SwipeRefresh (tarik ke bawah = reload) -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ===== SPLASH SCREEN ===== -->
    <FrameLayout
        android:id="@+id/splash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/splash_bg">

        <!-- Cahaya lembut di belakang logo -->
        <View
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:layout_marginBottom="60dp"
            android:background="@drawable/glow_radial" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <!-- 🖼️ LOGO TOKO123 -->
            <ImageView
                android:id="@+id/logo"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:src="@drawable/logo_splash" />

            <ProgressBar
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginTop="38dp"
                android:indeterminateTint="@color/notif_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.3"
                android:text="@string/loading"
                android:textColor="@color/splash_hint"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tulisan bawah -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="36dp"
            android:letterSpacing="0.2"
            android:text="@string/splash_tagline"
            android:textColor="@color/splash_hint"
            android:textSize="9sp" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
